    }

    .section-heading-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border-width: 1px;
    }

        .section-heading-icon svg {
            width: 14px;
            height: 14px;
        }

    .section-heading-title {
        font-size: 0.9rem;
        letter-spacing: 0;
        font-weight: 600;
        text-transform: none;
    }

    .section-heading-sub {
        font-size: 0.72rem;
