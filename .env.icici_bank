# ICICI Bank Voice AI Configuration
# Bridge Relay - FreeSWITCH to PersonaPlex (RunPod)

# ============================================================================
# Server Settings
# ============================================================================
BRIDGE_PORT=8001

# ============================================================================
# PersonaPlex Connection (RunPod)
# ============================================================================
# RunPod proxy URL (replace with your actual RunPod endpoint)
PERSONAPLEX_URL=wss://lhoac81oebncui-8998.proxy.runpod.net/api/chat

# API Key (if required by RunPod)
PERSONAPLEX_API_KEY=

# ============================================================================
# ICICI Bank Agent Configuration
# ============================================================================
# Agent ID (leave empty if using text prompt directly)
AGENT_ID=

# Bearer token for authentication
BEARER_TOKEN=

# Voice Model - NATF0.pt (Natural Female Voice 0)
VOICE_PROMPT=NATF0.pt

# ICICI Bank Customer Service Prompt
TEXT_PROMPT=You work for ICICI Bank and your name is Priya Sharma. You are a helpful and professional customer service representative specializing in personal accounts and loan products. You are currently assisting a customer who holds a personal savings account with a current balance of Rs 50,000. Your role is to help the customer with account balance, recent transactions, and loan products including personal loans, home loans, car loans, and education loans. Mention that ICICI Bank offers competitive personal loan rates starting from 10.5% per annum with flexible EMI options and instant approval for eligible customers. Always verify the customer's identity using registered mobile number and date of birth before sharing account details.

# ============================================================================
# TTS Settings (Fallback)
# ============================================================================
TTS_ENABLED=true
TTS_DIR=/tmp/bridge_tts
FS_CLI=/usr/local/freeswitch/bin/fs_cli

# ============================================================================
# Barge-in Settings (Customer Interruption)
# ============================================================================
# Enable barge-in (customer can interrupt agent)
BARGE_IN_ENABLED=true

# RMS threshold for detecting speech (lower = more sensitive)
BARGE_IN_RMS_THRESHOLD=0.012

# Minimum audio duration to trigger barge-in (seconds)
BARGE_IN_MIN_AUDIO_SEC=0.8

# Maximum audio duration for barge-in detection (seconds)
BARGE_IN_MAX_AUDIO_SEC=2.5

# ============================================================================
# Debug Settings
# ============================================================================
# Enable debug logging (set to true for troubleshooting)
DEBUG=false

# ============================================================================
# Notes
# ============================================================================
# 1. RunPod URL uses wss:// (secure WebSocket) instead of ws://
# 2. Voice NATF0.pt provides professional female voice suitable for banking
# 3. Barge-in is enabled to allow customers to interrupt long responses
# 4. TTS fallback ensures service continuity if PersonaPlex audio fails
# 5. Always verify customer identity before sharing account details
#
# Alternative Voice Options:
# - NATF1.pt - More professional tone
# - NATF3.pt - Warmer, friendlier tone
# - NATM0.pt - Male voice alternative
#
# To use this configuration:
# 1. Copy to .env: cp .env.icici_bank .env
# 2. Update PERSONAPLEX_URL with your actual RunPod endpoint
# 3. Add BEARER_TOKEN if required
# 4. Start bridge: python3 bridge_relay.py
