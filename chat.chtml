<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OmniCortex Chat</title>
    <style>
        :root {
            --color-background-primary: #ffffff;
            --color-background-secondary: #f8fafc;
            --color-background-tertiary: #f3f6fb;
            --color-border-secondary: #cfd8e3;
            --color-border-tertiary: #e2e8f0;
            --color-text-primary: #0f172a;
            --color-text-secondary: #64748b;
            --border-radius-md: 8px;
            --border-radius-lg: 14px;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background: var(--color-background-tertiary);
            color: var(--color-text-primary);
        }

        .chat-host {
            min-height: 100vh;
            padding: 24px;
            position: relative;
            box-sizing: border-box;
        }

        #demo-launcher {
            position: fixed;
            right: 24px;
            bottom: 24px;
            border: none;
            border-radius: 999px;
            padding: 11px 18px;
            font-weight: 600;
            font-size: 13px;
            background: #0d6efd;
            color: #fff;
            cursor: pointer;
            box-shadow: 0 4px 14px rgba(13,110,253,0.35);
            z-index: 1000;
        }

        #demo-popup {
            display: none;
            position: fixed;
            right: 24px;
            bottom: 76px;
            width: 360px;
            max-width: calc(100% - 48px);
            height: 460px;
            background: var(--color-background-primary);
            border: 0.5px solid var(--color-border-secondary);
            border-radius: var(--border-radius-lg);
            overflow: hidden;
            flex-direction: column;
            box-shadow: 0 8px 30px rgba(15,23,42,0.15);
            z-index: 1001;
        }

        .demo-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 14px;
            border-bottom: 0.5px solid var(--color-border-tertiary);
            background: var(--color-background-secondary);
        }

        .demo-title {
            margin: 0;
            font-size: 13px;
            font-weight: 500;
            color: var(--color-text-primary);
        }

        #demo-meta {
            font-size: 11px;
            color: var(--color-text-secondary);
            margin-top: 2px;
        }

        #demo-close {
            border: none;
            background: transparent;
            color: var(--color-text-secondary);
            font-size: 18px;
            cursor: pointer;
            line-height: 1;
            padding: 2px 6px;
        }

        #demo-config {
            display: grid;
            grid-template-columns: 1fr;
            gap: 6px;
            padding: 8px 10px;
            border-bottom: 0.5px solid var(--color-border-tertiary);
            background: var(--color-background-primary);
        }

        #demo-config input {
            width: 100%;
            box-sizing: border-box;
            border: 0.5px solid var(--color-border-secondary);
            border-radius: var(--border-radius-md);
            padding: 7px 9px;
            font-size: 12px;
            font-family: inherit;
            background: var(--color-background-primary);
            color: var(--color-text-primary);
            outline: none;
        }

        #demo-config input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.16);
        }

        #demo-messages {
            flex: 1 1 auto;
            overflow-y: auto;
            padding: 12px;
            background: var(--color-background-tertiary);
            display: flex;
            flex-direction: column;
            gap: 8px;
            min-height: 0;
        }

        .msg {
            max-width: 86%;
            padding: 9px 11px;
            border-radius: 10px;
            font-size: 13px;
            line-height: 1.5;
            white-space: pre-wrap;
            word-break: break-word;
        }

        .msg-user {
            align-self: flex-end;
            background: #dbeafe;
            color: #1e3a5f;
        }

        .msg-agent {
            align-self: flex-start;
            background: var(--color-background-primary);
            border: 0.5px solid var(--color-border-tertiary);
            color: var(--color-text-primary);
        }

        .msg-error {
            align-self: flex-start;
            background: #fef2f2;
            border: 0.5px solid #fecaca;
            color: #991b1b;
        }

        .demo-inputbar {
            display: flex;
            gap: 8px;
            padding: 10px;
            border-top: 0.5px solid var(--color-border-tertiary);
            background: var(--color-background-primary);
        }

        #demo-input {
            flex: 1;
            resize: none;
            box-sizing: border-box;
            border: 0.5px solid var(--color-border-secondary);
            border-radius: var(--border-radius-md);
            padding: 8px 10px;
            font-size: 13px;
            font-family: inherit;
            background: var(--color-background-primary);
            color: var(--color-text-primary);
            outline: none;
        }

        #demo-send {
            align-self: flex-end;
            border: none;
            border-radius: var(--border-radius-md);
            padding: 8px 14px;
            font-size: 12px;
            font-weight: 500;
            background: #0d6efd;
            color: #fff;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="chat-host">
        <button id="demo-launcher">Conversation</button>

        <div id="demo-popup">
            <div class="demo-header">
                <div>
                    <p class="demo-title">Agent conversation</p>
                    <div id="demo-meta">Session: not started</div>
                </div>
                <button id="demo-close">x</button>
            </div>

            <div id="demo-config">
                <input id="demo-api-base" placeholder="API base URL (e.g., http://localhost:8000)" />
                <input id="demo-agent-id" placeholder="Agent ID (UUID)" />
                <input id="demo-token" placeholder="Bearer token" />
                <input id="demo-user-id" placeholder="X-User-Id (optional)" />
            </div>

            <div id="demo-messages">
                <div class="msg msg-agent">Ready. Enter a message and click Send.</div>
            </div>

            <div class="demo-inputbar">
                <textarea id="demo-input" placeholder="Enter message..." rows="2"></textarea>
                <button id="demo-send">Send</button>
            </div>
        </div>
    </div>

    <script>
        (function () {
            const launcher = document.getElementById("demo-launcher");
            const popup = document.getElementById("demo-popup");
            const closeBtn = document.getElementById("demo-close");
            const sendBtn = document.getElementById("demo-send");
            const messages = document.getElementById("demo-messages");
            const input = document.getElementById("demo-input");
            const meta = document.getElementById("demo-meta");

            const apiBaseInput = document.getElementById("demo-api-base");
            const agentIdInput = document.getElementById("demo-agent-id");
            const tokenInput = document.getElementById("demo-token");
            const userIdInput = document.getElementById("demo-user-id");

            let sessionId = "";

            apiBaseInput.value = localStorage.getItem("chat_api_base") || window.location.origin;
            agentIdInput.value = localStorage.getItem("chat_agent_id") || "";
            tokenInput.value = localStorage.getItem("chat_api_token") || "";
            userIdInput.value = localStorage.getItem("chat_api_user_id") || "";

            function openPopup() {
                popup.style.display = "flex";
                input.focus();
            }

            function closePopup() {
                popup.style.display = "none";
            }

            function addMsg(type, text) {
                const div = document.createElement("div");
                div.className = "msg " + (
                    type === "user" ? "msg-user" :
                    type === "error" ? "msg-error" : "msg-agent"
                );
                div.textContent = text;
                messages.appendChild(div);
                messages.scrollTop = messages.scrollHeight;
            }

            launcher.addEventListener("click", function () {
                if (popup.style.display === "flex") closePopup();
                else openPopup();
            });
            closeBtn.addEventListener("click", closePopup);

            sendBtn.addEventListener("click", handleSend);
            input.addEventListener("keydown", function (e) {
                if (e.key === "Enter" && !e.shiftKey) {
                    e.preventDefault();
                    handleSend();
                }
            });

            async function handleSend() {
                const text = (input.value || "").trim();
                const API_BASE = (apiBaseInput.value || "").trim().replace(/\/+$/, "");
                const AGENT_ID = (agentIdInput.value || "").trim();
                const TOKEN = (tokenInput.value || "").trim();
                const USER_ID = (userIdInput.value || "").trim();

                if (!text) return;
                if (!API_BASE) return addMsg("error", "API base URL is required.");
                if (!AGENT_ID) return addMsg("error", "Agent ID is required.");
                if (!TOKEN) return addMsg("error", "Bearer token is required.");

                localStorage.setItem("chat_api_base", API_BASE);
                localStorage.setItem("chat_agent_id", AGENT_ID);
                localStorage.setItem("chat_api_token", TOKEN);
                localStorage.setItem("chat_api_user_id", USER_ID);

                addMsg("user", text);
                input.value = "";
                sendBtn.disabled = true;

                const headers = {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + TOKEN
                };
                if (USER_ID) headers["X-User-Id"] = USER_ID;

                const payload = {
                    id: AGENT_ID,
                    channel_name: "TEXT",
                    channel_type: "MARKETING",
                    query: text
                };
                if (sessionId) payload.session_id = sessionId;

                try {
                    const res = await fetch(API_BASE + "/query", {
                        method: "POST",
                        headers: headers,
                        body: JSON.stringify(payload)
                    });
                    const data = await res.json().catch(function () { return {}; });

                    if (!res.ok) {
                        addMsg("error", String((data && data.detail) || ("HTTP " + res.status)));
                        return;
                    }

                    addMsg("agent", data.answer || "(No answer)");
                    if (data.session_id) {
                        sessionId = data.session_id;
                        meta.textContent = "Session: " + sessionId;
                    }
                } catch (err) {
                    addMsg("error", "Request failed: " + (err && err.message ? err.message : "Unknown error"));
                } finally {
                    sendBtn.disabled = false;
                    input.focus();
                }
            }
        })();
    </script>
</body>
</html>
