        border-radius: 8px;
        background: #fff;
        font-size: 0.88rem;
        padding: 0.62rem 0.75rem;
        color: var(--c-text);
    }

        .hud-input:focus, .hud-select:focus, .hud-textarea:focus {
            border-color: #93c5fd;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
        }

    .hud-textarea {
        font-family: var(--font-body);
        line-height: 1.55;
        min-height: 170px;
        color: var(--c-text2);
    }

    .field-note {
        font-size: 0.72rem;
        color: var(--c-muted);
    }

        .field-note::before {
            display: none;
        }

    .file-alert-bar {
        border: 1px solid #dbeafe;
        background: #eff6ff;
        border-radius: 8px;
        margin-bottom: 0.8rem;
        padding: 0.6rem 0.8rem;
    }

        .file-alert-bar span {
            font-family: var(--font-body);
            font-size: 0.75rem;
            letter-spacing: 0;
            color: #1d4ed8;
        }

    .file-row {
        border: 1px solid var(--c-border);
        border-radius: 8px;
        background: #fff;
        margin-bottom: 0.5rem;
        padding: 0.7rem 0.8rem;
        box-shadow: none;
    }

        .file-row::before {
            display: none;
        }

        .file-row:hover {
            border-color: #bfdbfe;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.05);
        }

    .file-icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        font-size: 1rem;
    }

    .file-name {
        font-size: 0.84rem;
        font-weight: 500;
    }

    .file-type {
        font-family: var(--font-body);
        font-size: 0.7rem;
        letter-spacing: 0;
        margin-top: 1px;
    }

    .btn-view {
        border: 1px solid var(--c-border2);
        border-radius: 7px;
        background: #fff;
        color: var(--c-text2);
        font-family: var(--font-body);
        font-size: 0.74rem;
        letter-spacing: 0;
        padding: 0.4rem 0.75rem;
    }

        .btn-view:hover {
            background: #f8fafc;
            border-color: #93c5fd;
            color: #1d4ed8;
            box-shadow: none;
        }

    .arr {
        transition: transform .15s ease;
    }

    .empty-state p {
        font-family: var(--font-body);
        letter-spacing: 0;
        font-size: 0.8rem;
    }

    .panel-footer {
        border-top: 1px solid var(--c-border);
        background: #fbfcfe;
        padding: 0.9rem 1.1rem;
    }

    .btn-cancel {
        border: 1px solid var(--c-border2);
        border-radius: 8px;
        padding: 0.5rem 1rem;
        background: #fff;
        color: var(--c-text2);
        font-family: var(--font-body);
        font-size: 0.8rem;
        letter-spacing: 0;
        text-transform: none;
    }

    .btn-deploy {
        border-radius: 8px;
        padding: 0.56rem 1.1rem;
        box-shadow: none;
        font-family: var(--font-body);
        font-size: 0.8rem;
        letter-spacing: 0;
        text-transform: none;
        background: var(--c-accent);
    }

        .btn-deploy::before {
            display: none;
        }

        .btn-deploy:hover {
            background: var(--c-accent2);
            box-shadow: 0 8px 18px rgba(37, 99, 235, 0.22);
            transform: translateY(-1px);
        }

    #filePreviewModal .modal-content {
        border: 1px solid var(--c-border);
        border-radius: 10px;
    }

    #filePreviewModal .modal-header {
        border-bottom: 1px solid var(--c-border);
        background: #f8fafc;
    }

    #filePreviewModal .modal-title {
        font-family: var(--font-body);
        font-size: 0.9rem;
        letter-spacing: 0;
        color: var(--c-text2);
    }

    @@media (max-width: 768px) {
        .ag-wrap {
            padding: 0.75rem;
        }

        .panel-body {
            padding: 0.85rem;
        }

        .field-grid,
        .field-grid.triple {
            grid-template-columns: 1fr;
        }

        .ag-header {
            align-items: flex-start;
            flex-direction: column;
            gap: 8px;
        }

        .panel-footer {
            justify-content: stretch;
            display: grid;
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

<form method="post" asp-area="AI" asp-controller="AgentManagement" asp-action="AddAgent"
      id="EditAgentForm" enctype="multipart/form-data">
    <div class="ag-wrap">

        <div style="display:none">
            <input type="hidden" asp-for="AgentId">
            <input type="hidden" asp-for="UserId">
            <input type="hidden" asp-for="RoleType">
            <input type="hidden" asp-for="AgentType">
            <input type="hidden" asp-for="SubAgentType">
            <input type="hidden" asp-for="KnowledgeFiles">
            <input type="hidden" asp-for="ConversationEnd">
            <input type="hidden" asp-for="ConversationStarters">
            <input type="hidden" asp-for="Instructions">
            <input type="hidden" asp-for="AgentLogic">
            <input type="hidden" asp-for="GuId">
            <input type="hidden" asp-for="Rule">
            <input type="hidden" asp-for="Description">
            <input type="hidden" asp-for="Handler">
        </div>

        <!-- Header -->
        <div class="ag-header">
            <div class="ag-brand">
                <div class="ag-logo-ring">
                    <svg viewBox="0 0 24 24"><path d="M12 2a5 5 0 015 5 5 5 0 01-5 5 5 5 0 01-5-5 5 5 0 015-5m0 12c5.33 0 8 2.67 8 4v2H4v-2c0-1.33 2.67-4 8-4z" /></svg>
                </div>
                <div>
                    <div class="ag-title">OMNI · AGENT CONFIG</div>
                    <div class="ag-subtitle">SYSTEM · v2.4.1</div>
                </div>
            </div>
            <div class="status-chip">
                <span class="status-dot"></span>
                NODE ACTIVE
            </div>
        </div>

        <!-- Single Panel -->
        <div class="main-panel">

            <div class="panel-topbar">
                <div class="panel-section-label">AGENT CONFIGURATION</div>
                <div class="panel-indicators">
                    <span class="pi-r"></span><span class="pi-y"></span><span class="pi-g"></span>
                </div>
            </div>

            <div class="panel-body">

                <!-- ─── SECTION 1: Agent Details ─── -->
                <div class="section-block">
                    <div class="section-heading">
                        <div class="section-heading-icon shi-a">
                            <svg viewBox="0 0 24 24"><path d="M11 17h2v-6h-2v6zm1-15C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zM11 9h2V7h-2v2z" /></svg>
                        </div>
                        <div class="section-heading-text">
                            <div class="section-heading-title">Agent Details</div>
                            <div class="section-heading-sub">NAME · GOAL · PROMPT</div>
                        </div>
                        <div class="section-heading-line"></div>
                    </div>

                    <div class="field-grid">
                        <div>
                            <div class="field-label"><span class="label-line"></span><span class="label-text">Agent Name</span><span class="label-req">*</span></div>
                            <input asp-for="AgentName" class="hud-input" placeholder="e.g. Health Wellness Companion" />
                        </div>
                        <div>
                            <div class="field-label"><span class="label-line"></span><span class="label-text">Website</span><span class="label-req">*</span></div>
                            <input asp-for="Website" class="hud-input" placeholder="https://example.com" />
                        </div>
                    </div>
                    <div class="field-grid single">
                        <div>
                            <div class="field-label"><span class="label-line"></span><span class="label-text">System Prompt</span></div>
                            <textarea asp-for="SystemPrompt" class="hud-textarea" rows="10" readonly></textarea>
                            <div class="field-note">Defines agent personality, tone &amp; behavior ruleset</div>
                        </div>
                    </div>
                </div>

                <div class="section-divider"></div>

                <!-- ─── SECTION 2: Advanced ─── -->
                <div class="section-block">
                    <div class="section-heading">
                        <div class="section-heading-icon shi-b">
                            <svg viewBox="0 0 24 24"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" /></svg>
                        </div>
                        <div class="section-heading-text">
                            <div class="section-heading-title">Advanced Settings</div>
                            <div class="section-heading-sub">MODEL · TOKENS · TIMEOUT</div>
                        </div>
                        <div class="section-heading-line"></div>
                    </div>

                    <div class="field-grid triple">
                        <div>
                            <div class="field-label"><span class="label-line"></span><span class="label-text">LLM Model</span></div>
                            <select asp-for="LLMModel" class="hud-select">
                                <option value="">— Select Model —</option>
                                <option value="Meta Llama-3.1-8B-Instruct">Meta Llama-3.1-8B-Instruct</option>
                                <option value="Meta Llama-4-Maverick-17B-128E-Instruct">Meta Llama-4-Maverick-17B-128E-Instruct</option>
                            </select>
                        </div>
                        <div>
                            <div class="field-label"><span class="label-line"></span><span class="label-text">Max Tokens</span></div>
                            <input asp-for="MaxTokens" type="number" class="hud-input" min="200" max="128000" />
                        </div>
                        <div>
                            <div class="field-label"><span class="label-line"></span><span class="label-text">Timeout (sec)</span></div>
                            <input asp-for="TimeoutSeconds" type="number" class="hud-input" min="10" max="300" step="5" />
                        </div>
                    </div>
                    <div class="field-grid" style="grid-template-columns: 1fr 2fr;">
                        <div>
                            <div class="field-label"><span class="label-line"></span><span class="label-text">Agent Status</span></div>
                            <select asp-for="Status" class="hud-select">
                                <option value="">— Select Status —</option>
                                <option value="1">Pending</option>
                                <option value="2">Approved</option>
                                <option value="3">Deleted</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="section-divider"></div>

                <!-- ─── SECTION 3: Knowledge ─── -->
                <div class="section-block">
                    <div class="section-heading">
                        <div class="section-heading-icon shi-c">
                            <svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zM6 20V4h7v5h5v11H6z" /></svg>
                        </div>
                        <div class="section-heading-text">
                            <div class="section-heading-title">Knowledge Base</div>
                            <div class="section-heading-sub">FILES · CONTEXT · SEARCH</div>
                        </div>
                        <div class="section-heading-line"></div>
                    </div>

                    <div class="file-alert-bar">
                        <svg viewBox="0 0 24 24"><path d="M11 17h2v-6h-2v6zm1-8a1 1 0 100-2 1 1 0 000 2z" /></svg>
                        <span>SUPPORTED FORMATS: PDF · TXT · CSV · IMAGE · VIDEO</span>
                    </div>

                    @if (Model != null && Model.DocumentData != null)
                    {
                        var docsList = Model.DocumentData.DocumentsText;
                        var imagesList = Model.DocumentData.ImageUrls;
                        var videosList = Model.DocumentData.VideoUrls;
                        bool hasAnyFile = (docsList != null && docsList.Count > 0) ||
                        (imagesList != null && imagesList.Count > 0) ||
                        (videosList != null && videosList.Count > 0);

                        if (hasAnyFile)
                        {
                            @if (docsList != null)
                            {
                                foreach (var doc in docsList.Where(d => d != null && d.Type != null && d.Type.ToLower() == "txt"))
                                {
                                    <div class="file-row">
                                        <div class="file-icon fi-txt"><i class="bi bi-file-earmark-text"></i></div>
                                        <div class="file-info">
                                            <div class="file-name">@(doc.Url != null ? doc.Url.Split('/').Last() : "Unknown")</div>
                                            <div class="file-type">TXT</div>
                                        </div>
                                        <button class="btn-view" type="button" onclick="openFileModal('@doc.Url','txt','@(doc.Url.Split('/').Last())')">VIEW <span class="arr">→</span></button>
                                    </div>
                                }
                                foreach (var doc in docsList.Where(d => d != null && d.Type != null && d.Type.ToLower() == "csv"))
                                {
                                    <div class="file-row">
                                        <div class="file-icon fi-csv"><i class="bi bi-file-earmark-spreadsheet"></i></div>
                                        <div class="file-info">
                                            <div class="file-name">@(doc.Url != null ? doc.Url.Split('/').Last() : "Unknown")</div>
                                            <div class="file-type">CSV</div>
                                        </div>
                                        <button class="btn-view" type="button" onclick="openFileModal('@doc.Url','csv','@(doc.Url.Split('/').Last())')">VIEW <span class="arr">→</span></button>
                                    </div>
                                }
                                foreach (var doc in docsList.Where(d => d != null && d.Type != null && d.Type.ToLower() == "pdf"))
                                {
                                    <div class="file-row">
                                        <div class="file-icon fi-pdf"><i class="bi bi-file-earmark-pdf"></i></div>
                                        <div class="file-info">
                                            <div class="file-name">@(doc.Url != null ? doc.Url.Split('/').Last() : "Unknown")</div>
                                            <div class="file-type">PDF</div>
                                        </div>
                                        <button class="btn-view" type="button" onclick="openFileModal('@doc.Url','pdf','@(doc.Url.Split('/').Last())')">VIEW <span class="arr">→</span></button>
                                    </div>
                                }
                            }
                            @if (imagesList != null)
                            {
                                foreach (var imageUrl in imagesList.Where(x => !string.IsNullOrEmpty(x)))
                                {
                                    <div class="file-row">
                                        <div class="file-icon fi-img"><img src="@imageUrl" alt="img" style="width:38px;height:38px;object-fit:cover;" /></div>
                                        <div class="file-info">
                                            <div class="file-name">@imageUrl.Split('/').Last()</div>
                                            <div class="file-type">IMAGE</div>
                                        </div>
                                        <button class="btn-view" type="button" onclick="openFileModal('@imageUrl','image','@(imageUrl.Split('/').Last())')">VIEW <span class="arr">→</span></button>
                                    </div>
                                }
                            }
                            @if (videosList != null)
                            {
                                foreach (var videoUrl in videosList.Where(x => !string.IsNullOrEmpty(x)))
                                {
                                    <div class="file-row">
                                        <div class="file-icon fi-vid"><i class="bi bi-camera-video"></i></div>
                                        <div class="file-info">
                                            <div class="file-name">@videoUrl.Split('/').Last()</div>
                                            <div class="file-type">VIDEO</div>
                                        </div>
                                        <button class="btn-view" type="button" onclick="openFileModal('@videoUrl','video','@(videoUrl.Split('/').Last())')">VIEW <span class="arr">→</span></button>
                                    </div>
                                }
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <i class="bi bi-folder2-open"></i>
                                <p>NO FILES UPLOADED · KNOWLEDGE BASE EMPTY</p>
                            </div>
                        }
                    }
                </div>

            </div>

            <div class="panel-footer">
                <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn-deploy">Update Agent <span class="arr">→</span></button>
            </div>
        </div>

    </div>
</form>

<!-- Modal -->
<div class="modal fade" id="filePreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="modalFileName">FILE PREVIEW</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" onclick="clearModal()"></button>
            </div>
            <div class="modal-body p-0" id="modalBody" style="min-height:500px;"></div>
        </div>
    </div>
</div>

<script src="~/projectlibs/ai/editagent.js"></script>
