# =============================================================================
# OmniCortex Example Environment (safe template)
# Copy to `.env` and set real values.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgresdb@localhost:5432/omnicortex

# -----------------------------------------------------------------------------
# AUTH
# -----------------------------------------------------------------------------
MASTER_API_KEY=replace-with-strong-secret
AUTH_VERIFY_URL=https://your-auth-host.example/api/v1/omnicortex/me
AUTH_VERIFY_TIMEOUT=8

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN_REGEX=^https://.*\\.proxy\\.runpod\\.net$|^https://.*\\.trycloudflare\\.com$

# -----------------------------------------------------------------------------
# PRIMARY + SECONDARY LLM BACKENDS
# -----------------------------------------------------------------------------
VLLM1_BASE_URL=http://localhost:8080/v1
VLLM1_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM1_API_KEY=not-needed

VLLM2_BASE_URL=http://localhost:8081/v1
VLLM2_MODEL=meta-llama/Llama-4-Maverick-17B-128E-Instruct
VLLM2_API_KEY=not-needed

# Backward-compatible aliases (optional)
VLLM_BASE_URL=http://localhost:8080/v1
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_API_KEY=not-needed
LLAMA_BASE_URL=http://localhost:8081/v1
LLAMA_MODEL=meta-llama/Llama-4-Maverick-17B-128E-Instruct
LLAMA_API_KEY=not-needed

LLM_TEMPERATURE=0.6

# -----------------------------------------------------------------------------
# RAG
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024
CHUNK_SIZE=700
CHUNK_OVERLAP=120
USE_SEMANTIC_CHUNKING=true
TOP_K_RESULTS=4
USE_RERANKER=true
RERANKER_MODEL_NAME=BAAI/bge-reranker-large

# -----------------------------------------------------------------------------
# MEMORY + STORAGE
# -----------------------------------------------------------------------------
DEFAULT_MAX_HISTORY=5
MAX_HISTORY_LIMIT=20
STORAGE_PATH=storage

# -----------------------------------------------------------------------------
# MOSHI / PERSONAPLEX
# -----------------------------------------------------------------------------
MOSHI_ENABLED=true
PERSONAPLEX_MODEL=nvidia/personaplex-7b-v1
PERSONAPLEX_URL=http://localhost:8998
MOSHI_API_TOKEN=
MOSHI_ENABLE_OMNICORTEX_UI_PATCH=1

# Optional prompt enrichment for /voice/ws
VOICE_RAG_ENABLED=true
VOICE_RAG_TOP_K=3
VOICE_APPEND_CLIENT_PROMPT=false

# -----------------------------------------------------------------------------
# VOICE GATEWAY (scripts/voice_gateway.py)
# -----------------------------------------------------------------------------
VOICE_GATEWAY_HOST=0.0.0.0
VOICE_GATEWAY_PORT=8099
VOICE_GATEWAY_ENDPOINT=/calls
OMNICORTEX_VOICE_WS=ws://127.0.0.1:8000/voice/ws
VOICE_GATEWAY_AGENT_ID=
VOICE_GATEWAY_TOKEN=
VOICE_GATEWAY_VOICE_PROMPT=NATF0.pt
VOICE_GATEWAY_SEED=-1
VOICE_GATEWAY_INBOUND_MODE=pcm16
VOICE_GATEWAY_OUTBOUND_MODE=pcm16
VOICE_GATEWAY_FS_SR=8000
VOICE_GATEWAY_MOSHI_SR=24000
VOICE_GATEWAY_FORWARD_TEXT_FRAMES=0
VOICE_GATEWAY_UPSTREAM_SSL_VERIFY=0
VOICE_GATEWAY_TIMEOUT_SEC=1800
VOICE_GATEWAY_SSL_CERT=
VOICE_GATEWAY_SSL_KEY=

# -----------------------------------------------------------------------------
# CLICKHOUSE (optional)
# -----------------------------------------------------------------------------
CLICKHOUSE_ENABLED=false
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=omnicortex

# -----------------------------------------------------------------------------
# WHATSAPP (optional)
# -----------------------------------------------------------------------------
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v24.0
WHATSAPP_VERIFY_TOKEN=omnicortex_token
WHATSAPP_FLOW_MODE=published

# -----------------------------------------------------------------------------
# HUGGINGFACE (optional for downloads)
# -----------------------------------------------------------------------------
HUGGING_FACE_HUB_TOKEN=
HF_HUB_ENABLE_HF_TRANSFER=0
