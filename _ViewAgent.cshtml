@using OmniApp.Domain.Commons
@model OmniApp.Domain.AIModels.AIAgentModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap');

    :root {
        --c-bg: #f0f4f8;
        --c-surface: #ffffff;
        --c-border: #d0e4f7;
        --c-border2: #a8cff0;
        --c-accent: #0a7cf5;
        --c-accent2: #00c6e0;
        --c-text: #0f1c2e;
        --c-text2: #3a5575;
        --c-muted: #8aabcc;
        --c-green: #00c896;
        --c-orange: #ff7340;
        --font-head: 'Orbitron', monospace;
        --font-body: 'Inter', sans-serif;
    }

    .ag-wrap * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .ag-wrap {
        font-family: var(--font-body);
        background: var(--c-bg);
        color: var(--c-text);
        padding: 2rem;
        min-height: 100vh;
        position: relative;
        overflow: hidden;
    }

        .ag-wrap::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: linear-gradient(rgba(10,124,245,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(10,124,245,0.04) 1px, transparent 1px);
            background-size: 48px 48px;
            pointer-events: none;
            z-index: 0;
        }

        .ag-wrap::after {
            content: '';
            position: fixed;
            top: -80px;
            right: -80px;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(0,198,224,0.12) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        .ag-wrap > * {
            position: relative;
            z-index: 1;
        }

    /* HEADER */
    .ag-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.75rem;
        padding-bottom: 1.25rem;
        border-bottom: 1.5px solid var(--c-border);
    }

    .ag-brand {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .ag-logo-ring {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        border: 2px solid var(--c-accent2);
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(0,198,224,0.1), rgba(10,124,245,0.06));
        position: relative;
    }

        .ag-logo-ring::after {
            content: '';
            position: absolute;
            inset: 4px;
            border-radius: 50%;
            border: 1px dashed rgba(10,124,245,0.3);
            animation: spin 10s linear infinite;
        }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .ag-logo-ring svg {
        width: 20px;
        height: 20px;
        fill: var(--c-accent);
    }

    .ag-title {
        font-family: var(--font-head);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        color: var(--c-accent);
        text-transform: uppercase;
        line-height: 1;
    }

    .ag-subtitle {
        font-family: var(--font-head);
        font-size: 0.6rem;
        color: var(--c-muted);
        letter-spacing: 0.1em;
        margin-top: 4px;
        font-weight: 400;
    }

    .status-chip {
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: var(--font-head);
        font-size: 0.6rem;
        letter-spacing: 0.1em;
        color: var(--c-text2);
    }

    .status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--c-green);
        box-shadow: 0 0 6px var(--c-green);
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1)
        }

        50% {
            opacity: 0.6;
            transform: scale(0.85)
        }
    }

    /* MAIN PANEL */
    .main-panel {
        background: var(--c-surface);
        border: 1.5px solid var(--c-border);
        border-radius: 14px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 2px 24px rgba(10,124,245,0.06);
    }

        .main-panel::before {
            content: '';
            position: absolute;
            top: -1px;
            left: -1px;
            width: 24px;
            height: 24px;
            border-top: 3px solid var(--c-accent);
            border-left: 3px solid var(--c-accent);
            border-radius: 12px 0 0 0;
            z-index: 2;
        }

        .main-panel::after {
            content: '';
            position: absolute;
            bottom: -1px;
            right: -1px;
            width: 24px;
            height: 24px;
            border-bottom: 3px solid var(--c-accent2);
            border-right: 3px solid var(--c-accent2);
            border-radius: 0 0 12px 0;
            z-index: 2;
        }

    .panel-topbar {
        padding: 0.85rem 1.5rem;
        border-bottom: 1.5px solid var(--c-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(90deg, rgba(10,124,245,0.03), transparent);
    }

    .panel-section-label {
        font-family: var(--font-head);
        font-size: 0.62rem;
        letter-spacing: 0.2em;
        color: var(--c-accent);
        font-weight: 600;
    }

    .panel-indicators {
        display: flex;
        gap: 5px;
    }

        .panel-indicators span {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

    .pi-r {
        background: #ff5f57;
    }

    .pi-y {
        background: #febc2e;
    }

    .pi-g {
        background: var(--c-green);
        box-shadow: 0 0 5px var(--c-green);
    }

    .panel-body {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
    }

    /* SECTION BLOCK */
    .section-block {
    }

    /* Section heading row */
    .section-heading {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.5rem;
    }

    .section-heading-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .section-heading-icon svg {
            width: 18px;
            height: 18px;
        }

    .shi-a {
        background: rgba(255,179,50,0.1);
        border: 1.5px solid rgba(255,179,50,0.25);
    }

    .shi-b {
        background: rgba(0,200,150,0.1);
        border: 1.5px solid rgba(0,200,150,0.25);
    }

    .shi-c {
        background: rgba(10,124,245,0.08);
        border: 1.5px solid rgba(10,124,245,0.2);
    }

    .shi-a svg {
        fill: #e08b00;
    }

    .shi-b svg {
        fill: #00a87a;
    }

    .shi-c svg {
        fill: var(--c-accent);
    }

    .section-heading-text {
    }

    .section-heading-title {
        font-family: var(--font-head);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        color: var(--c-text);
        text-transform: uppercase;
    }

    .section-heading-sub {
        font-family: var(--font-head);
        font-size: 0.55rem;
        color: var(--c-muted);
        letter-spacing: 0.1em;
        margin-top: 2px;
    }

    .section-heading-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, var(--c-border), transparent);
    }

    /* Divider between sections */
    .section-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--c-border), transparent);
        margin: 0;
    }

    /* FIELDS */
    .field-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
        margin-bottom: 1.25rem;
    }

        .field-grid.single {
            grid-template-columns: 1fr;
        }

        .field-grid.triple {
            grid-template-columns: 1fr 1fr 1fr;
        }

        .field-grid:last-child {
            margin-bottom: 0;
        }

    @@media(max-width: 768px) {
        .field-grid, .field-grid.triple {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media(max-width: 560px) {
        .field-grid, .field-grid.triple {
            grid-template-columns: 1fr;
        }

        .ag-status-bar {
            display: none;
        }
    }

    .field-label {
        display: flex;
        align-items: center;
        gap: 7px;
        margin-bottom: 7px;
    }

    .label-line {
        width: 14px;
        height: 2px;
        background: linear-gradient(90deg, var(--c-accent), var(--c-accent2));
        border-radius: 2px;
        flex-shrink: 0;
    }

    .label-text {
        font-family: var(--font-head);
        font-size: 0.6rem;
        letter-spacing: 0.15em;
        color: var(--c-text2);
        font-weight: 600;
        text-transform: uppercase;
    }

    .label-req {
        color: var(--c-orange);
        margin-left: 2px;
        font-size: 0.75rem;
    }

    .hud-input, .hud-select, .hud-textarea {
        width: 100%;
        background: #f5f9ff;
        border: 1.5px solid var(--c-border);
        border-radius: 8px;
        color: var(--c-text);
        font-family: var(--font-body);
        font-size: 0.88rem;
        padding: 0.62rem 1rem;
        outline: none;
        transition: all 0.18s;
        -webkit-appearance: none;
    }

        .hud-input:focus, .hud-select:focus, .hud-textarea:focus {
            border-color: var(--c-accent);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(10,124,245,0.1);
        }

        .hud-input::placeholder {
            color: var(--c-muted);
            font-size: 0.84rem;
        }

    .hud-select {
        cursor: pointer;
    }

    .hud-textarea {
        font-family: 'Courier New', monospace;
        font-size: 0.82rem;
        line-height: 1.7;
        resize: vertical;
        min-height: 200px;
        color: #1a4a7a;
    }

    .field-note {
        font-size: 0.7rem;
        color: var(--c-muted);
        margin-top: 6px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .field-note::before {
            content: '';
            display: inline-block;
            width: 10px;
            height: 1px;
            background: var(--c-muted);
        }

    /* FILES */
    .file-alert-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0.65rem 1rem;
        background: rgba(10,124,245,0.05);
        border: 1.5px solid rgba(10,124,245,0.15);
        border-radius: 8px;
        margin-bottom: 1rem;
    }

        .file-alert-bar svg {
            width: 15px;
            height: 15px;
            fill: var(--c-accent);
            flex-shrink: 0;
        }

        .file-alert-bar span {
            font-family: var(--font-head);
            font-size: 0.6rem;
            letter-spacing: 0.1em;
            color: var(--c-accent);
        }

    .file-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0.85rem 1rem;
        border: 1.5px solid var(--c-border);
        border-radius: 9px;
        background: #fafcff;
        margin-bottom: 0.6rem;
        transition: all 0.18s;
        position: relative;
        overflow: hidden;
    }

        .file-row::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(180deg, var(--c-accent), var(--c-accent2));
            border-radius: 3px 0 0 3px;
        }

        .file-row:hover {
            border-color: var(--c-accent2);
            box-shadow: 0 2px 12px rgba(10,124,245,0.08);
        }

    .file-icon {
        width: 38px;
        height: 38px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.1rem;
    }

    .fi-txt {
        background: #f1f3f5;
        border: 1.5px solid #dde1e7;
    }

    .fi-csv {
        background: rgba(0,200,150,0.08);
        border: 1.5px solid rgba(0,200,150,0.25);
    }

    .fi-pdf {
        background: rgba(255,115,64,0.08);
        border: 1.5px solid rgba(255,115,64,0.25);
    }

    .fi-img {
        border: 1.5px solid var(--c-border);
        overflow: hidden;
    }

    .fi-vid {
        background: rgba(10,124,245,0.06);
        border: 1.5px solid rgba(10,124,245,0.2);
    }

    .file-info {
        flex: 1;
        min-width: 0;
    }

    .file-name {
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--c-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .file-type {
        font-family: var(--font-head);
        font-size: 0.55rem;
        letter-spacing: 0.12em;
        color: var(--c-muted);
        margin-top: 2px;
    }

    .btn-view {
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 0.38rem 0.9rem;
        background: transparent;
        border: 1.5px solid var(--c-border2);
        border-radius: 6px;
        color: var(--c-accent);
        font-family: var(--font-head);
        font-size: 0.58rem;
        letter-spacing: 0.1em;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
    }

        .btn-view:hover {
            background: rgba(10,124,245,0.06);
            border-color: var(--c-accent);
            box-shadow: 0 0 10px rgba(10,124,245,0.15);
        }

    .empty-state {
        text-align: center;
        padding: 2.5rem 1rem;
        color: var(--c-muted);
    }

        .empty-state i {
            font-size: 2.5rem;
            opacity: 0.3;
            display: block;
            margin-bottom: 0.75rem;
        }

        .empty-state p {
            font-family: var(--font-head);
            font-size: 0.65rem;
            letter-spacing: 0.12em;
        }

    /* FOOTER */
    .panel-footer {
        padding: 1rem 1.75rem;
        border-top: 1.5px solid var(--c-border);
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.75rem;
        background: linear-gradient(90deg, transparent, rgba(10,124,245,0.02));
    }

    .btn-cancel {
        padding: 0.58rem 1.5rem;
        background: transparent;
        border: 1.5px solid var(--c-border);
        border-radius: 8px;
        color: var(--c-text2);
        font-family: var(--font-head);
        font-size: 0.62rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.15s;
    }

        .btn-cancel:hover {
            border-color: var(--c-text2);
            color: var(--c-text);
        }

    .btn-deploy {
        position: relative;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0.62rem 1.75rem;
        background: linear-gradient(135deg, var(--c-accent) 0%, var(--c-accent2) 100%);
        border: none;
        border-radius: 8px;
        color: #fff;
        font-family: var(--font-head);
        font-size: 0.65rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.22s;
        overflow: hidden;
        box-shadow: 0 4px 14px rgba(10,124,245,0.3);
    }

        .btn-deploy::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transform: translateX(-100%);
            transition: transform 0.5s;
        }

        .btn-deploy:hover::before {
            transform: translateX(100%);
        }

        .btn-deploy:hover {
            box-shadow: 0 6px 22px rgba(10,124,245,0.45);
            transform: translateY(-1px);
        }

    .arr {
        transition: transform 0.2s;
    }

    .btn-deploy:hover .arr {
        transform: translateX(3px);
    }

    /* MODAL */
    #filePreviewModal .modal-content {
        border: 1.5px solid var(--c-border);
        border-radius: 12px;
        overflow: hidden;
    }

    #filePreviewModal .modal-header {
        background: linear-gradient(90deg, rgba(10,124,245,0.04), transparent);
        border-bottom: 1.5px solid var(--c-border);
        padding: 1rem 1.5rem;
    }

    #filePreviewModal .modal-title {
        font-family: var(--font-head);
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        color: var(--c-accent);
    }
</style>

<style>
