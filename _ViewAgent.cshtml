    }

    .section-divider {
        background: var(--c-border);
    }

    .field-grid {
        gap: 0.9rem;
        margin-bottom: 0.9rem;
    }

    .field-label {
        margin-bottom: 6px;
        gap: 6px;
    }

    .label-line {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--c-accent);
    }

    .label-text {
        font-family: var(--font-body);
